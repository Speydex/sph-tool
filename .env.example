# Zugangsdaten Schulportal Hessen
# Kopiere diese Datei zu ".env" und trage deine echten Daten ein.
# Die .env wird durch .gitignore NICHT eingecheckt.

SPH_USERNAME=vorname.nachname
SPH_PASSWORD=deinPasswort

# Schul-ID aus der Login-URL (?i=XXXX). 6105 = aus deiner URL.
SPH_SCHOOL_ID=6105

# --- Krypto-Test-Trading-Bot (Bybit Demo-Trading, virtuelles Geld) --------
# API-Key im Bybit-Dashboard unter "Demo Trading" erzeugen (oben rechts
# umschalten). Funktioniert NUR fuer das Demo-Konto, nicht fuer echtes Geld.
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_BASE_URL=https://api-demo.bybit.com

CRYPTO_SYMBOL=BTCUSDT
CRYPTO_INTERVAL=15
CRYPTO_SMA_SHORT=9
CRYPTO_SMA_LONG=21
CRYPTO_TRADE_USDT=20
