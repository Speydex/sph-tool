# Zugangsdaten Schulportal Hessen
# Kopiere diese Datei zu ".env" und trage deine echten Daten ein.
# Die .env wird durch .gitignore NICHT eingecheckt.

SPH_USERNAME=vorname.nachname
SPH_PASSWORD=deinPasswort

# Schul-ID aus der Login-URL (?i=XXXX). 6105 = aus deiner URL.
SPH_SCHOOL_ID=6105

# --- Krypto-Test-Bot (reine Simulation, kein Account, kein echtes Geld) --
# Kurse kommen oeffentlich von CoinGecko (kein Login, kein API-Key). Kauf/
# Verkauf passiert nur virtuell in state/crypto_portfolio.json.
CRYPTO_COIN_ID=bitcoin
CRYPTO_VS_CURRENCY=usd
CRYPTO_SMA_SHORT=9
CRYPTO_SMA_LONG=21
CRYPTO_START_BALANCE=1000
